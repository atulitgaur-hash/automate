# Optional — Adzuna (https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional — JSearch via RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=

# Path to a plain-text resume for keyword scoring (optional)
RESUME_PATH=resume.txt

# SQLite database path
DATABASE_URL=sqlite:///./data/jobs.db

# Auto-refresh cron (leave empty to disable; default daily 8am)
REFRESH_CRON=0 8 * * *